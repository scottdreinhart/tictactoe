{
  "name": "tictactoe-game",
  "version": "1.0.0",
  "description": "Tic-Tac-Toe",
  "type": "module",
  "private": true,
  "license": "PROPRIETARY",
  "author": "Scott Reinhart",
  "main": "electron/main.js",
  "scripts": {
    "dev": "kill-port 5173 2>/dev/null || true; vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "electron:dev": "concurrently --kill-others \"vite --host\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:pack": "electron-builder --dir",
    "cap:sync": "vite build && cap sync",
    "cap:android": "cap open android",
    "cap:ios": "cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^8.2.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^5.1.4",
    "astral-regex": "^2.0.0",
    "babel-plugin-transform-react-remove-prop-types": "^0.4.24",
    "concurrently": "^9.1.2",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^5.14.0",
    "vite": "^5.4.21",
    "wait-on": "^8.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.scottreinhart.tictactoe",
    "productName": "Tic-Tac-Toe",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "public/icon-192.png",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon-192.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon-192.png"
    }
  }
}
