{
  "name": "tictactoe-game",
  "version": "1.0.0",
  "description": "Tic-Tac-Toe",
  "type": "module",
  "private": true,
  "license": "PROPRIETARY",
  "author": "Scott Reinhart",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": "24.14.0",
    "npm": "11.9.0",
    "pnpm": "10.31.0"
  },
  "main": "electron/main.js",
  "scripts": {
    "start": "rimraf node_modules/.vite && vite --host",
    "start:nocache": "rimraf node_modules/.vite && vite --mode nocache --host",
    "dev": "rimraf node_modules/.vite && vite --host",
    "dev:nocache": "rimraf node_modules/.vite && vite --mode nocache --host",
    "dev:clean": "pnpm clean && pnpm install && pnpm dev",
    "prebuild": "pnpm clean:dist",
    "build": "rimraf node_modules/.vite && vite build",
    "build:clean": "pnpm clean && pnpm install && pnpm build",
    "build:preview": "pnpm build && pnpm preview",
    "preview": "vite preview",
    "analyze": "pnpm build && pnpm exec open-cli dist/bundle-report.html",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck",
    "fix": "pnpm lint:fix && pnpm format",
    "validate": "pnpm check && pnpm build",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ci": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "clean:cache": "rimraf node_modules/.vite",
    "clean:dist": "rimraf dist release",
    "clean": "rimraf node_modules",
    "clean:all": "rimraf dist release node_modules",
    "install:linux": "npm_config_platform=linux npm_config_arch=x64 pnpm install --force",
    "install:windows": "npm_config_platform=win32 npm_config_arch=x64 pnpm install --force",
    "reinstall": "pnpm clean:all && pnpm install",
    "wasm:build": "node scripts/build-wasm.js",
    "wasm:build:debug": "node scripts/build-wasm.js --debug",
    "deps:check": "pnpm outdated || true",
    "deps:audit": "pnpm audit",
    "desktop:dev": "concurrently -k \"pnpm dev\" \"wait-on http://localhost:5173 && electron .\"",
    "desktop:preview": "pnpm build && electron .",
    "desktop:build": "pnpm build && electron-builder",
    "windows:build": "pnpm build && electron-builder --win",
    "linux:build": "pnpm build && electron-builder --linux",
    "mac:build": "pnpm build && electron-builder --mac",
    "android:init": "pnpm exec cap add android",
    "android:sync": "pnpm build && pnpm exec cap sync android",
    "android:open": "pnpm exec cap open android",
    "android:run": "pnpm exec cap run android",
    "android:build": "pnpm build && pnpm exec cap sync android && cd android && gradlew assembleDebug",
    "ios:init": "pnpm exec cap add ios",
    "ios:sync": "pnpm build && pnpm exec cap sync ios",
    "ios:open": "pnpm exec cap open ios",
    "ios:run": "pnpm exec cap run ios",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@capacitor/android": "8.2.0",
    "@capacitor/core": "8.2.0",
    "@esbuild/linux-x64": "0.27.3",
    "@rollup/rollup-linux-x64-gnu": "4.59.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@capacitor/cli": "8.2.0",
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "assemblyscript": "0.28.10",
    "astral-regex": "2.0.0",
    "concurrently": "9.2.1",
    "electron": "40.8.0",
    "electron-builder": "26.8.1",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-boundaries": "5.4.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "husky": "9.1.7",
    "jsdom": "28.1.0",
    "kill-port": "2.0.1",
    "lint-staged": "16.3.3",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "rimraf": "6.1.3",
    "rollup-plugin-visualizer": "5.14.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vite": "7.3.1",
    "vitest": "4.0.18",
    "wait-on": "8.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.scottreinhart.tictactoe",
    "productName": "Tic-Tac-Toe",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
