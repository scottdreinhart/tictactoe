{
  "name": "tictactoe-game",
  "version": "1.0.0",
  "description": "Tic-Tac-Toe",
  "type": "module",
  "private": true,
  "license": "PROPRIETARY",
  "author": "Scott Reinhart",
  "main": "electron/main.js",
  "scripts": {
    "start": "vite --host",
    "dev": "kill-port 5173 2>/dev/null || true; vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "build:preview": "pnpm build && pnpm preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "check": "pnpm lint && pnpm format:check",
    "fix": "pnpm lint:fix && pnpm format",
    "validate": "pnpm check && pnpm build",
    "clean": "rimraf dist release",
    "clean:node": "rimraf node_modules",
    "clean:all": "rimraf dist release node_modules",
    "reinstall": "pnpm clean:all && pnpm install",
    "prebuild": "pnpm clean",
    "analyze": "vite build && npx open-cli dist/bundle-report.html",
    "deps:check": "pnpm outdated || true",
    "deps:audit": "pnpm audit",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:linux": "vite build && electron-builder --linux",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:preview": "pnpm build && electron .",
    "cap:init:android": "npx cap add android",
    "cap:init:ios": "npx cap add ios",
    "cap:sync": "vite build && npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run:android": "npx cap run android",
    "cap:run:ios": "npx cap run ios",
    "cap:build:android": "vite build && npx cap sync && cd android && gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^5.1.4",
    "astral-regex": "^2.0.0",
    "babel-plugin-transform-react-remove-prop-types": "^0.4.24",
    "concurrently": "^9.1.2",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^5.14.0",
    "vite": "^7.3.1",
    "wait-on": "^8.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.scottreinhart.tictactoe",
    "productName": "Tic-Tac-Toe",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "public/icon-192.png",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon-192.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon-192.png"
    }
  }
}
